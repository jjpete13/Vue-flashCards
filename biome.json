{
  "linter": {
    "rules": {
      "suspicious": {
        "noAssignInExpressions": "warn"
      },
      "complexity": {
        "noForEach": "warn"
      }
    },
    "ignore": ["dist/**/*", "node_modules/**/*", "docs/**/*"]
  },
  "formatter": {
    "ignore": ["dist/**/*", "node_modules/**/*", "docs/**/*"]
  }
}
